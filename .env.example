# MT5 MCP 設定例。コピーして .env を作成してください。
# MT5 が既にログイン済みなら認証情報は省略可能です。

# --- 接続 ---
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_LOGIN=12345678
# MT5_PASSWORD=your-password
# MT5_SERVER=YourBroker-Demo
MT5_TIMEOUT=60000

# --- 発注ガード（安全のため既定は無効）---
# 発注ツールを有効化する場合のみ true。まずはデモ口座で。
MT5_TRADE_ENABLED=false
# 二段階確認（confirm=true 必須）。false で即時発注（非推奨）。
MT5_TRADE_CONFIRM=true
# 1注文あたり最大ロット
MT5_MAX_LOT=0.01
# 許容スリッページ(points)
MT5_MAX_SLIPPAGE=20
# 発注を許可するシンボル（カンマ区切り、* で全許可）
MT5_ALLOWED_SYMBOLS=*
# 注文のマジックナンバー
MT5_MAGIC=20260610

# --- ログ ---
# 監査ログの出力先（既定: ~/.mt5_mcp/trade_audit.log）
# MT5_LOG_DIR=C:\Users\jun\.mt5_mcp

# --- HTTP公開（start-remote.ps1 / Cloudflareトンネル用）---
# stdio既定。HTTPで公開する場合のみ設定（start-remote.ps1 が自動設定）。
# MT5_MCP_TRANSPORT=http
MT5_MCP_HTTP_HOST=127.0.0.1
MT5_MCP_HTTP_PORT=8790
MT5_MCP_HTTP_PATH=/mcp
# 公開時は必須。未設定だとHTTP起動を拒否（実発注を不特定多数に晒さないため）。
# 強力なランダム文字列を設定すること。
# MT5_MCP_TOKEN=replace-with-a-long-random-secret
# どうしても無認証で公開する場合のみ true（非推奨）。
# MT5_MCP_ALLOW_NO_AUTH=false
# Hostヘッダ検証（DNSリバインディング保護）。既定は無効＝任意Host許可
# （Cloudflareトンネルは毎回ランダムなホスト名のため）。固定したい場合のみ
# カンマ区切りで許可ホストを指定する（例: my.example.com,localhost:8790）。
# MT5_MCP_ALLOWED_HOSTS=
